    "@types/nodemailer": "^8.0.1",
    "algoliasearch": "^5.52.1",
    "axios": "^1.17.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
