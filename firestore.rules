rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function girisYapilmis() {
      return request.auth != null;
    }

    // Bir sohbetin katılımcısı mı? (mesajlar alt-koleksiyonu için)
    function sohbetKatilimcisiMi(sohbetId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/sohbetler/$(sohbetId)).data.kullanicilar;
    }

    // favoriSayisi / goruntulenmeSayisi sadece ±1 değişebilir.
    function gecerliSayacGuncellemesi() {
      let degisenAlanlar = request.resource.data.diff(resource.data).affectedKeys();
      let eskiFavori        = resource.data.get('favoriSayisi', 0);
      let yeniFavori         = request.resource.data.get('favoriSayisi', 0);
      let eskiGoruntulenme  = resource.data.get('goruntulenmeSayisi', 0);
      let yeniGoruntulenme   = request.resource.data.get('goruntulenmeSayisi', 0);
      return degisenAlanlar.hasOnly(['favoriSayisi', 'goruntulenmeSayisi'])
        && (!degisenAlanlar.hasAny(['favoriSayisi']) ||
              yeniFavori == eskiFavori + 1 || yeniFavori == eskiFavori - 1)
        && (!degisenAlanlar.hasAny(['goruntulenmeSayisi']) ||
              yeniGoruntulenme == eskiGoruntulenme + 1);
    }

    // Takip oluşturulunca/silinince karşı taraftaki sayaç ±1 değişebilir.
    // getAfter kilidi: bu transaction'da gerçek bir takip belgesi var mı?
    function takipSayaciGecerliMi(uid) {
      let alanlar = request.resource.data.diff(resource.data).affectedKeys();
      let eskiTakipci = resource.data.get('takipciSayisi', 0);
      let yeniTakipci = request.resource.data.get('takipciSayisi', 0);
      let eskiTakip   = resource.data.get('takipSayisi', 0);
      let yeniTakip   = request.resource.data.get('takipSayisi', 0);
      // Karşı tarafın takipciSayisi: ancak AYNI işlemde gerçek takip
      // belgesi oluşuyorsa (+1) ya da siliniyorsa (-1) değişebilir.
      let takipId = request.auth.uid + '_' + uid;
      return (alanlar.hasOnly(['takipciSayisi']) && (
                (yeniTakipci == eskiTakipci + 1
                   && !exists(/databases/$(database)/documents/takipler/$(takipId))
                   && existsAfter(/databases/$(database)/documents/takipler/$(takipId)))
             || (yeniTakipci == eskiTakipci - 1
                   && exists(/databases/$(database)/documents/takipler/$(takipId))
                   && !existsAfter(/databases/$(database)/documents/takipler/$(takipId)))
             ))
          // Kendi takipSayisi: karşı taraf bu bağlamda bilinemez, existsAfter kilidi kurulamaz.
          // BİLİNEN TAVİZ: kullanıcı kendi takip sayısını ±1 şişirebilir (düşük risk).
          // Kalıcı çözüm: sayaçları CF trigger'a taşımak.
          || (alanlar.hasOnly(['takipSayisi']) && request.auth.uid == uid
                && (yeniTakip == eskiTakip + 1 || yeniTakip == eskiTakip - 1));
    }

    match /kullanicilar/{uid} {
      allow get: if true;
      allow list: if false;
      allow create: if girisYapilmis() && request.auth.uid == uid;
      allow update: if girisYapilmis() && (
        (request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ortalamaPuan', 'degerlendirmeSayisi', 'takipciSayisi',
                     'takipSayisi', 'rozetler', 'guvenSkoru',
                     'spamUyarisi', 'spamTarihi', 'spamIlanSayisi'])
        ) ||
        takipSayaciGecerliMi(uid)
      );

      match /bekleyenDegerlendirmeler/{sohbetId} {
        allow read, write: if girisYapilmis()
          && request.auth.uid == uid;
      }
    }

    match /ilanlar/{ilanId} {
      allow get, list: if true;
      allow create: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid;
      allow update: if girisYapilmis() && (
        resource.data.kullaniciId == request.auth.uid ||
        gecerliSayacGuncellemesi()
      );
      allow delete: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
    }

    match /sohbetler/{sohbetId} {
      allow get, list: if girisYapilmis()
        && request.auth.uid in resource.data.kullanicilar;
      allow create: if girisYapilmis()
        && request.auth.uid in request.resource.data.kullanicilar;
      allow update: if girisYapilmis()
        && request.auth.uid in resource.data.kullanicilar;

      match /mesajlar/{mesajId} {
        allow get, list: if girisYapilmis() && (
          !exists(/databases/$(database)/documents/sohbetler/$(sohbetId)) ||
          sohbetKatilimcisiMi(sohbetId)
        );
        allow create: if girisYapilmis()
          && request.resource.data.gondereId == request.auth.uid;
        allow update: if girisYapilmis()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['okundu'])
          && resource.data.gondereId != request.auth.uid
          && request.resource.data.okundu == true;
        allow delete: if girisYapilmis()
          && resource.data.gondereId == request.auth.uid;
      }
    }

    match /favoriler/{favoriId} {
      allow get, list: if girisYapilmis()
        && (resource == null || resource.data.kullaniciId == request.auth.uid);
      allow create: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid;
      allow delete: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
    }

    match /goruntulenmeler/{kayitId} {
      allow read: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
      allow write: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid
        && request.resource.data.keys().hasAll(['kullaniciId', 'ilanId', 'sonTarih']);
    }

    match /degerlendirmeler/{degId} {
      allow get, list: if true;
      allow create: if girisYapilmis()
        && request.resource.data.degerlendireninId == request.auth.uid
        && request.resource.data.hedefKullaniciId != request.auth.uid
        && request.resource.data.puan is int
        && request.resource.data.puan >= 1
        && request.resource.data.puan <= 5;
    }

    match /bildirimler/{bildirimId} {
      allow get, list, update, delete: if girisYapilmis()
        && (resource == null || resource.data.kullaniciId == request.auth.uid);
      allow create: if girisYapilmis()
        && request.resource.data.gondereId == request.auth.uid
        && request.resource.data.kullaniciId is string
        && request.resource.data.kullaniciId.size() > 0;
    }

    match /sikayetler/{sikayetId} {
      allow get, list: if false;
      allow create: if girisYapilmis()
        && request.resource.data.sikayetEdenId == request.auth.uid;
    }

    match /takipler/{takipId} {
      allow read: if girisYapilmis();
      allow create: if girisYapilmis()
        && request.auth.uid == request.resource.data.takipciId;
      allow delete: if girisYapilmis()
        && request.auth.uid == resource.data.takipciId;
    }

    match /trendler/{trendId} {
      allow read: if girisYapilmis();
      allow write: if false;
    }
  }
}
