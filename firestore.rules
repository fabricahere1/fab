rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // YARDIMCI FONKSİYONLAR
    // ═══════════════════════════════════════════════════════════════════

    function girisYapilmis() {
      return request.auth != null;
    }

    function sohbetKatilimcisiMi(sohbetId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/sohbetler/$(sohbetId)).data.kullanicilar;
    }

    // YENİ (3. teyit turu): mesajGonder() sohbet dokümanını VE mesaj
    // dokümanını AYNI batch'te yazıyor. Yeni bir sohbetin İLK mesajında,
    // sohbet dokümanı commit ÖNCESİ hiç yok — düz get()/exists() (sonu
    // "After" olmayanlar) yalnızca commit ÖNCESİ durumu görür, batch
    // içindeki kardeş yazmayı GÖRMEZ. getAfter() ise commit SONRASI
    // durumu okur — existsAfter()'ın (bu dosyada zaten kullanılan) tam
    // eşleniği. mesajGonder HER mesajda (ilk dahil) kullanicilar alanını
    // yazdığı için, bu fonksiyon hem ilk hem sonraki mesajlarda doğru
    // çalışır. Yalnızca CREATE'te kullanılır — update/get/list'te sohbet
    // zaten var olduğu için düz sohbetKatilimcisiMi() yeterli ve doğru.
    function sohbetKatilimcisiMiCreateSirasinda(sohbetId) {
      return request.auth.uid in
        getAfter(/databases/$(database)/documents/sohbetler/$(sohbetId)).data.kullanicilar;
    }

    // YENİ, İKİ YÖNLÜ: ne alıcı gönderen kişiyi engellemiş olabilir, ne de
    // gönderen alıcıyı engellemiş olabilir — mesaj create'i ikisinde de
    // reddedilir. sohbetKatilimcisiMiCreateSirasinda() ile AYNI gerekçe/
    // aynı teknik: yeni bir sohbetin İLK mesajında sohbet dokümanı commit
    // ÖNCESİ yok, bu yüzden ALICIYI BULMAK için getAfter() kullanılıyor
    // (düz get() kullanılsaydı, taze bir sohbette ilk mesaj HER ZAMAN bu
    // kontrolde patlardı — kullanicilar alanı henüz "var" görünmezdi).
    // Alıcının VE gönderenin kendi profil dokümanları (kullanicilar/{uid})
    // ise bu batch'in bir parçası DEĞİL, önceden var olan dokümanlar —
    // o yüzden ikisi için de düz get() (getAfter değil) doğru ve yeterli.
    function birbiriniEngellememis(sohbetId) {
      let katilimcilar = getAfter(/databases/$(database)/documents/sohbetler/$(sohbetId)).data.kullanicilar;
      let aliciUid = katilimcilar[0] == request.auth.uid ? katilimcilar[1] : katilimcilar[0];
      let aliciRef = /databases/$(database)/documents/kullanicilar/$(aliciUid);
      let benimRef = /databases/$(database)/documents/kullanicilar/$(request.auth.uid);
      let aliciBeniEngellememis = !exists(aliciRef)
        || !(request.auth.uid in get(aliciRef).data.get('engellenenler', []));
      let benOnuEngellememisim = !exists(benimRef)
        || !(aliciUid in get(benimRef).data.get('engellenenler', []));
      return aliciBeniEngellememis && benOnuEngellememisim;
    }

    // DEĞİŞTİ: artık gerçek bir favoriler/goruntulenmeler dokümanının aynı
    // transaction'da oluşup silindiğini de doğruluyor — takipSayaciGecerliMi()
    // ile birebir aynı desen.
    function gecerliSayacGuncellemesi(ilanId) {
      let degisenAlanlar   = request.resource.data.diff(resource.data).affectedKeys();
      let eskiFavori       = resource.data.get('favoriSayisi', 0);
      let yeniFavori       = request.resource.data.get('favoriSayisi', 0);
      let eskiGoruntulenme = resource.data.get('goruntulenmeSayisi', 0);
      let yeniGoruntulenme = request.resource.data.get('goruntulenmeSayisi', 0);
      let favoriId         = request.auth.uid + '_' + ilanId;
      let goruntulenmeId   = request.auth.uid + '_' + ilanId;

      return degisenAlanlar.hasOnly(['favoriSayisi', 'goruntulenmeSayisi'])
        && (!degisenAlanlar.hasAny(['favoriSayisi']) || (
              (yeniFavori == eskiFavori + 1
                 && !exists(/databases/$(database)/documents/favoriler/$(favoriId))
                 && existsAfter(/databases/$(database)/documents/favoriler/$(favoriId)))
           || (yeniFavori == eskiFavori - 1
                 && exists(/databases/$(database)/documents/favoriler/$(favoriId))
                 && !existsAfter(/databases/$(database)/documents/favoriler/$(favoriId)))
           ))
        && (!degisenAlanlar.hasAny(['goruntulenmeSayisi']) ||
              (yeniGoruntulenme == eskiGoruntulenme + 1
                 && existsAfter(/databases/$(database)/documents/goruntulenmeler/$(goruntulenmeId))));
    }

    function takipSayaciGecerliMi(uid) {
      let alanlar     = request.resource.data.diff(resource.data).affectedKeys();
      let eskiTakipci = resource.data.get('takipciSayisi', 0);
      let yeniTakipci = request.resource.data.get('takipciSayisi', 0);
      let eskiTakip   = resource.data.get('takipSayisi', 0);
      let yeniTakip   = request.resource.data.get('takipSayisi', 0);
      let takipId     = request.auth.uid + '_' + uid;
      return (alanlar.hasOnly(['takipciSayisi']) && (
                (yeniTakipci == eskiTakipci + 1
                   && !exists(/databases/$(database)/documents/takipler/$(takipId))
                   && existsAfter(/databases/$(database)/documents/takipler/$(takipId)))
             || (yeniTakipci == eskiTakipci - 1
                   && exists(/databases/$(database)/documents/takipler/$(takipId))
                   && !existsAfter(/databases/$(database)/documents/takipler/$(takipId)))
             ))
          || (alanlar.hasOnly(['takipSayisi']) && request.auth.uid == uid
                && (yeniTakip == eskiTakip + 1 || yeniTakip == eskiTakip - 1));
    }

    // YENİ: değerlendirme yazan gerçekten bu sohbetin tarafı mı, hedef de
    // sohbetin diğer tarafı mı, işlem gerçekten tamamlanmış mı (teslimAlindi),
    // ve daha önce KENDİ adına bu sohbette değerlendirme yapmamış mı.
    function degerlendirmeGecerliMi(sohbetId, hedefId) {
      let sohbet = get(/databases/$(database)/documents/sohbetler/$(sohbetId)).data;
      return request.auth.uid in sohbet.kullanicilar
        && hedefId in sohbet.kullanicilar
        && hedefId != request.auth.uid
        && sohbet.get('islemDurumlari', {}).get('teslimAlindi', false) == true
        && sohbet.get('degerlendirmeYapildi_' + request.auth.uid, false) == false;
    }

    // YENİ: tek taraflı bir işlem adımı (siparisVerildi/urunAlindi/yolaCikti/
    // teslimEdildi/teslimAlindi) yalnızca "true" VE "<adim>_yapanUid == benim
    // uid'im" birlikte, aynı yazmada set edilirse geçerli sayılır — böylece
    // biri karşı tarafın onayını taklit edemez.
    function tekTarafliAdimGecerliMi(yeniD, eskiD, adim, benimUid) {
      let adimDegisti  = yeniD.get(adim, false) != eskiD.get(adim, false);
      let yapanDegisti = yeniD.get(adim + '_yapanUid', '') != eskiD.get(adim + '_yapanUid', '');
      return (!adimDegisti && !yapanDegisti)
        || (yeniD.get(adim, false) == true
              && yeniD.get(adim + '_yapanUid', '') == benimUid);
    }

    // YENİ: sohbetler.islemDurumlari alt-haritasında değişebilecek anahtarlar
    // sabit/bilinen bir listeyle sınırlanıyor (islem_durumu.dart'taki
    // IlanTipiAdimlar ile birebir), her tek-taraflı adım için yapan-doğrulaması
    // yapılıyor, ve "anlasildi_X" yalnızca kendi uid'iniz için yazılabiliyor.
    function sohbetGuncellemeGecerliMi() {
      let benimUid = request.auth.uid;
      let eskiD = resource.data.get('islemDurumlari', {});
      let yeniD = request.resource.data.get('islemDurumlari', {});
      let bilinenAnahtarlar = [
        'iletisimBasladi',
        'anlasildi_' + benimUid,
        'siparisVerildi', 'siparisVerildi_yapanUid',
        'urunAlindi', 'urunAlindi_yapanUid',
        'yolaCikti', 'yolaCikti_yapanUid',
        'teslimEdildi', 'teslimEdildi_yapanUid',
        'teslimAlindi', 'teslimAlindi_yapanUid',
      ];
      let degisenAnahtarlar = yeniD.diff(eskiD).affectedKeys();

      return degisenAnahtarlar.hasOnly(bilinenAnahtarlar)
        && tekTarafliAdimGecerliMi(yeniD, eskiD, 'siparisVerildi', benimUid)
        && tekTarafliAdimGecerliMi(yeniD, eskiD, 'urunAlindi',     benimUid)
        && tekTarafliAdimGecerliMi(yeniD, eskiD, 'yolaCikti',      benimUid)
        && tekTarafliAdimGecerliMi(yeniD, eskiD, 'teslimEdildi',   benimUid)
        && tekTarafliAdimGecerliMi(yeniD, eskiD, 'teslimAlindi',   benimUid);
    }

    // DÜZELTME (2. teyit turu): mesajGonder() HER mesajda 'kullanicilar':
    // [gondereId, karsiId] yazıyor — kim gönderiyorsa dizide önce o oluyor,
    // yani A→B mesajında [A,B], B→A cevabında [B,A]. Diziler rules'ta sıraya
    // duyarlı karşılaştırılır; "hiç değişemez" kısıtı her karşılıklı
    // cevaplaşmada patlardı. Bunun yerine: hâlâ aynı 2 kişi mi (sırasız) diye
    // bakıyoruz — üçüncü bir kişi eklenemez/değiştirilemez ama sıra serbest.
    function kullanicilarGecerliMi() {
      let yeni = request.resource.data.kullanicilar;
      return yeni.size() == 2
        && request.auth.uid in yeni
        && (!('kullanicilar' in resource.data) ||
             (resource.data.kullanicilar.size() == 2
               && yeni[0] in resource.data.kullanicilar
               && yeni[1] in resource.data.kullanicilar));
    }

    // ═══════════════════════════════════════════════════════════════════
    // KULLANICILAR — değişmedi
    // ═══════════════════════════════════════════════════════════════════

    match /kullanicilar/{uid} {
      allow get: if true;
      allow list: if false;
      allow create: if girisYapilmis() && request.auth.uid == uid;
      allow update: if girisYapilmis() && (
        (request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ortalamaPuan', 'degerlendirmeSayisi', 'takipciSayisi',
                     'takipSayisi', 'rozetler', 'guvenSkoru',
                     'spamUyarisi', 'spamTarihi', 'spamIlanSayisi'])
        ) ||
        takipSayaciGecerliMi(uid)
      );

      match /bekleyenDegerlendirmeler/{sohbetId} {
        allow read, write: if girisYapilmis() && request.auth.uid == uid;
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // İLANLAR — DEĞİŞTİ: moderasyon alanları client'tan yazılamaz
    // ═══════════════════════════════════════════════════════════════════

    match /ilanlar/{ilanId} {
      allow get, list: if true;

      // Yeni ilan her zaman moderasyon bekler durumda doğar — client
      // kendini doğrudan 'yayinda' olarak açamaz. (ilanModerasyonu trigger'ı
      // zaten bunu koşulsuz eziyor; bu, tetiklenene kadarki anlık pencereyi
      // de kapatan ekstra bir savunma katmanı.)
      allow create: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid
        && request.resource.data.get('durum', 'onayBekliyor') == 'onayBekliyor'
        && request.resource.data.get('aktif', false) == false;

      // Sahip; durum/onerilenPuan/algoliaHata/kullaniciPuan HARİÇ her alanı
      // düzenleyebilir — bu alanlar yalnızca Admin SDK (Cloud Functions)
      // tarafından yazılabilir. DÜZELTME (2. teyit turu): redSebebi
      // kısıtlaması KALDIRILDI — ilanResimliGuncelle() reddedilen bir ilanı
      // yeniden göndermek için tam olarak redSebebi:'' yazıyor, bunu
      // engellemek gerçek bir özelliği kırardı; asıl güvenlik zaten
      // durum/aktif kısıtından geliyor. aktif alanı SADECE true→false
      // (kendi ilanını pasife alma — ilanPasifYap) yönünde serbest;
      // false→true (kendi kendini yeniden aktife alma = moderasyon bypass)
      // kilitli — bu ayrım olmadan ilanPasifYap() kırılırdı.
      // DÜZELTME (emulator testi B4'ün ortaya çıkardığı gerçek açık — test
      // saldırganı yanlışlıkla ilanın sahibi olarak kurmuştu, ama bu tam da
      // gerçek bir boşluğu ifşa etti): favoriSayisi/goruntulenmeSayisi
      // eskiden sahiplik dalında HİÇ kısıtlı değildi — sahip, kendi ilanına
      // hiç favorilemeden/görüntülemeden bu sayıları serbestçe yazabiliyordu
      // (gecerliSayacGuncellemesi()'ye hiç uğramadan). Artık bu iki alan da
      // sahiplik dalında yasaklı — HERKES (sahip dahil) bu sayıları yalnızca
      // gecerliSayacGuncellemesi() üzerinden, gerçek bir favoriler/
      // goruntulenmeler dokümanı karşılığında değiştirebilir.
      allow update: if girisYapilmis() && (
        (resource.data.kullaniciId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['onerilenPuan', 'algoliaHata', 'kullaniciPuan',
                        'favoriSayisi', 'goruntulenmeSayisi'])
          && (request.resource.data.get('durum', '') == resource.data.get('durum', '')
              || request.resource.data.durum == 'onayBekliyor')
          && (request.resource.data.get('aktif', false) == resource.data.get('aktif', false)
              || request.resource.data.aktif == false)
        ) ||
        gecerliSayacGuncellemesi(ilanId)
      );

      allow delete: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════
    // SOHBETLER — DEĞİŞTİ: islemDurumlari artık taklit edilemiyor
    // ═══════════════════════════════════════════════════════════════════

    match /sohbetler/{sohbetId} {
      allow get, list: if girisYapilmis()
        && request.auth.uid in resource.data.kullanicilar;
      allow create: if girisYapilmis()
        && request.auth.uid in request.resource.data.kullanicilar;

      // NOT — DEĞERLENDİRMEYAPILDI_X İÇİN ÖNEMLİ SINIR:
      // 'degerlendirmeYapildi_' + uid dinamik adlı bir ÜST SEVİYE alan
      // (map değil), bu yüzden rules'ta "yalnızca kendi anahtarınız
      // değişebilir, başkasınınki asla" genel kısıtlamasını buradan ifade
      // edemiyoruz (hangi uid'lerin var olabileceğini önceden bilemeyiz).
      // BU YÜZDEN BU ALAN AŞAĞIDA KISITLANMADI — karşı tarafın
      // "değerlendirdi" bayrağını hâlâ teorik olarak flip edebilirsiniz.
      // Kalıcı/temiz çözüm: bu alanı 'degerlendirmeYapildi: {uid: bool}'
      // şeklinde TEK bir map alanına taşımak (degerlendirme_repository.dart'ta
      // tek satırlık değişiklik) — o zaman islemDurumlari'nda kullandığımız
      // aynı "yalnızca kendi anahtarın" deseni buraya da uygulanabilir.
      // Pratik etki düşük: bu bayrak yalnızca "değerlendirme ekranını tekrar
      // gösterme" amaçlı bir UI kısayolu, kendisi puan/veri bütünlüğünü
      // BOZMAZ (asıl koruma yukarıdaki degerlendirmeGecerliMi()'de).
      allow update: if girisYapilmis()
        && request.auth.uid in resource.data.kullanicilar
        && kullanicilarGecerliMi()
        && sohbetGuncellemeGecerliMi();

      match /mesajlar/{mesajId} {
        allow get, list: if girisYapilmis() && (
          !exists(/databases/$(database)/documents/sohbetler/$(sohbetId)) ||
          sohbetKatilimcisiMi(sohbetId)
        );

        // DEĞİŞTİ: gönderenin gerçekten bu sohbetin tarafı olduğu doğrulanıyor.
        // getAfter() kullanıyor (bkz. yukarıdaki fonksiyon yorumu) — düz get()
        // kullansaydı, yeni bir sohbetin ilk mesajı HER ZAMAN reddedilirdi.
        // YENİ, İKİ YÖNLÜ: alıcı gönderen kişiyi engellemişse YA DA
        // gönderen alıcıyı engellemişse (kullanicilar/{uid}.engellenenler,
        // her iki taraf da) mesaj create'i reddedilir — client tarafındaki
        // (ilan_detay_screen.dart, mesaj_repository.dart) iki yönlü
        // kontrolün rules seviyesindeki karşılığı.
        allow create: if girisYapilmis()
          && request.resource.data.gondereId == request.auth.uid
          && sohbetKatilimcisiMiCreateSirasinda(sohbetId)
          && birbiriniEngellememis(sohbetId);

        // DEĞİŞTİ: okundu işaretleyenin de gerçekten sohbetin tarafı olduğu
        // doğrulanıyor.
        allow update: if girisYapilmis()
          && sohbetKatilimcisiMi(sohbetId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['okundu'])
          && resource.data.gondereId != request.auth.uid
          && request.resource.data.okundu == true;

        allow delete: if girisYapilmis()
          && resource.data.gondereId == request.auth.uid;
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // FAVORİLER / GÖRÜNTÜLENMELER — DEĞİŞTİ: doküman ID'si kilitlendi
    // ═══════════════════════════════════════════════════════════════════

    match /favoriler/{favoriId} {
      allow get, list: if girisYapilmis()
        && (resource == null || resource.data.kullaniciId == request.auth.uid);
      allow create: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid
        && favoriId == request.auth.uid + '_' + request.resource.data.ilanId;
      allow delete: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
    }

    match /goruntulenmeler/{kayitId} {
      allow read: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
      // DÜZELTME (2. teyit turu): eskiden tek bir 'allow write' create/
      // update/delete'i birlikte kapsıyordu — ama delete'te request.resource
      // diye bir şey YOK (null), request.resource.data.ilanId erişimi
      // delete anında hata verirdi. create/update/delete ayrıldı.
      allow create: if girisYapilmis()
        && request.resource.data.kullaniciId == request.auth.uid
        && request.resource.data.keys().hasAll(['kullaniciId', 'ilanId', 'sonTarih'])
        && kayitId == request.auth.uid + '_' + request.resource.data.ilanId;
      allow update: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid
        && request.resource.data.kullaniciId == request.auth.uid
        && request.resource.data.keys().hasAll(['kullaniciId', 'ilanId', 'sonTarih']);
      allow delete: if girisYapilmis()
        && resource.data.kullaniciId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════
    // DEĞERLENDİRMELER — DEĞİŞTİ: gerçek ilişki + tamamlanmış işlem şartı
    // ═══════════════════════════════════════════════════════════════════

    match /degerlendirmeler/{degId} {
      allow get, list: if true;
      allow create: if girisYapilmis()
        && request.resource.data.degerlendireninId == request.auth.uid
        && request.resource.data.hedefKullaniciId != request.auth.uid
        && request.resource.data.puan is int
        && request.resource.data.puan >= 1
        && request.resource.data.puan <= 5
        && request.resource.data.sohbetId is string
        && degerlendirmeGecerliMi(request.resource.data.sohbetId, request.resource.data.hedefKullaniciId);
    }

    // ═══════════════════════════════════════════════════════════════════
    // BİLDİRİMLER — DEĞİŞTİ: alıcı, paylaşılan bir sohbetin tarafı olmalı
    // ═══════════════════════════════════════════════════════════════════

    match /bildirimler/{bildirimId} {
      allow get, list, update, delete: if girisYapilmis()
        && (resource == null || resource.data.kullaniciId == request.auth.uid);

      // NOT: Sunucu (Admin SDK) yazmaları bu bloğa hiç tabi değil — bu
      // yalnızca client'tan gelen direkt yazmaları (mesaj_repository.dart
      // → _islemBildirimiYaz) kapsıyor; orada hedefId her zaman bir
      // sohbetId, alıcı da o sohbetin diğer tarafı. Client'tan farklı bir
      // ilişki tipiyle bildirim yazan başka bir akış eklerseniz bu
      // fonksiyonu genişletmeniz gerekir.
      allow create: if girisYapilmis()
        && request.resource.data.gondereId == request.auth.uid
        && request.resource.data.kullaniciId is string
        && request.resource.data.kullaniciId.size() > 0
        && request.resource.data.hedefId is string
        && request.resource.data.hedefId.size() > 0
        && sohbetKatilimcisiMi(request.resource.data.hedefId)
        && request.resource.data.kullaniciId in
             get(/databases/$(database)/documents/sohbetler/$(request.resource.data.hedefId)).data.kullanicilar;
    }

    // ═══════════════════════════════════════════════════════════════════
    // ŞİKAYETLER — değişmedi
    // ═══════════════════════════════════════════════════════════════════

    match /sikayetler/{sikayetId} {
      allow get, list: if false;
      allow create: if girisYapilmis()
        && request.resource.data.sikayetEdenId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════
    // TAKİPLER — DEĞİŞTİ: kendini takip engellendi, doküman ID kilitlendi.
    // 'read' BİLİNÇLİ OLARAK aynen bırakıldı (3. teyit turunda düzeltildi):
    // önceki taslakta 'get, list: if girisYapilmis()' önerilmişti ama bu,
    // AYNI koşulla yazılan 'read: if girisYapilmis()' ile tamamen eşdeğer
    // — hiçbir şeyi kısıtlamıyordu, yalnızca yazım değişikliğiydi. Takip
    // verisi zaten uygulama içinde herkesin herkesin takipçi/takip listesini
    // görebildiği bir tasarım (takip_listesi_screen.dart) — bu bir hardening
    // hedefi değil.
    // ═══════════════════════════════════════════════════════════════════

    match /takipler/{takipId} {
      allow read: if girisYapilmis();
      allow create: if girisYapilmis()
        && request.auth.uid == request.resource.data.takipciId
        && request.resource.data.takipEdilenId != request.auth.uid
        && takipId == request.auth.uid + '_' + request.resource.data.takipEdilenId;
      allow delete: if girisYapilmis()
        && request.auth.uid == resource.data.takipciId;
    }

    // ═══════════════════════════════════════════════════════════════════
    // AYARLAR — DEĞİŞMEDİ, bu turda geri eklendi (Fable'ın gerçek
    // firestore.rules diff'i bu bloğun ilk taslakta eksik kaldığını
    // gösterdi — orijinal olarak bana paylaşılan rules metninde de bu
    // blok yoktu, dolayısıyla hiç görmemiştim; production dosyasıyla
    // birebir diff alınmadan bu tür eksikler yakalanamaz).
    // ═══════════════════════════════════════════════════════════════════

    match /ayarlar/{dokuman} {
      allow read: if true;
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════
    // TRENDLER — değişmedi
    // ═══════════════════════════════════════════════════════════════════

    match /trendler/{trendId} {
      allow read: if girisYapilmis();
      allow write: if false;
    }
  }
}